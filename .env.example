# Database (use com docker compose up -d; ver docker-compose.yml)
DATABASE_URL="postgresql://saas:saas@localhost:5432/saas_boilerplate"

# Auth.js (obrigatório: openssl rand -base64 32)
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# OAuth (opcional — deixe vazio para desabilitar)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Resend (magic link)
RESEND_API_KEY="re_"
EMAIL_FROM="noreply@yourdomain.com"

# Stripe
STRIPE_SECRET_KEY="sk_"
STRIPE_WEBHOOK_SECRET="whsec_"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_"
STRIPE_PRO_PRICE_ID="price_"

# Opcionais
SENTRY_DSN=""
LOG_LEVEL="info"
